{# ───────────────────────────────────────────────────────────────────
   WhatsApp Floating Button
   ----------------------------------------------------------------
   Single anchor in fixed position. Country resolution happens at
   render time (Jinja), not in JS, so the right number is baked into
   the href on first paint — no flicker, no client-side routing.

   Country mapping precedence:
     1. Per-country override list matching `session.country.code`
     2. Default number from settings

   Visibility:
     - Toggled off entirely if `whatsapp_fab_enabled` is false
     - Skipped on cart / shipping_payment pages when corresponding
       hide flags are on
     - Skipped if no usable number is configured (default empty AND
       no per-country override matches)

   Settings live under the "whatsapp_fab" group in layout.schema.json
   so access is `settings.whatsapp_fab_*`.
   ─────────────────────────────────────────────────────────────────── #}

{% if settings.whatsapp_fab_enabled %}
  {# ── Hide on specific templates ────────────────────────────── #}
  {% set _hide = false %}
  {% if settings.whatsapp_fab_hide_on_cart and session.template == 'cart_page' %}
    {% set _hide = true %}
  {% endif %}
  {% if settings.whatsapp_fab_hide_on_shipping_payment and session.template == 'shipping_payment' %}
    {% set _hide = true %}
  {% endif %}

  {% if not _hide %}
    {# ── Country override resolution ───────────────────────────
       Walk the merchant's per-country list (max 20 items) and pick
       the first one whose ISO code matches the visitor's country.
       Fall back to the default number/message if nothing matches. #}
    {% set _country_code = (session.country.code | upper) if session.country and session.country.code else '' %}
    {% set ns = namespace(number=settings.whatsapp_fab_default_number, message=settings.whatsapp_fab_default_message) %}
    {% if settings.whatsapp_fab_numbers and _country_code %}
      {% for entry in settings.whatsapp_fab_numbers %}
        {% if entry.country_code and (entry.country_code | upper) == _country_code %}
          {% if entry.number %}{% set ns.number = entry.number %}{% endif %}
          {% if entry.message and entry.message | trim %}{% set ns.message = entry.message %}{% endif %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {# ── Sanitize the number for wa.me — keep digits only.
       wa.me chokes on anything that isn't 0–9. Strips:
         - common separators: space, dash, plus, parens, dot, slash
         - NBSP (U+00A0) merchants paste from Word
         - LRM/RLM directional marks (U+200E / U+200F) that Arabic-locale
           OS keyboards silently insert when typing digits in an RTL field
       If a merchant pasted "Saudi 966-50…" the letters survive and break
       the URL — schema info string warns digits-only, but in practice
       most pasted numbers come out clean after this chain. #}
    {% set _digits = ns.number
        | replace(' ', '')
        | replace('-', '')
        | replace('+', '')
        | replace('(', '')
        | replace(')', '')
        | replace('.', '')
        | replace('/', '')
        | replace(' ', '')
        | replace('‎', '')
        | replace('‏', '') %}

    {% if _digits | length > 0 %}
      {# ── Build the message body. Optionally append the current
         page URL so the merchant sees where the customer was
         when they clicked. URL is computed client-side at click
         time so it stays accurate even on caches. #}
      {% set _msg_base = ns.message or '' %}

      {# ── Position class drives logical CSS properties so RTL is
         automatic — `inset-block-end + inset-inline-end` already
         maps correctly on `dir="rtl"` documents. #}
      {% set _position = settings.whatsapp_fab_position | default('middle-start', true) %}
      {% set _offset_x = settings.whatsapp_fab_offset_x | default(16, true) %}
      {% set _offset_y = settings.whatsapp_fab_offset_y | default(24, true) %}
      {% set _pulse    = settings.whatsapp_fab_pulse %}

      {# ── Accessible label.
         We hardcode an Arabic/English pair instead of going through the
         `_()` translation hook because the msgid `Chat on WhatsApp` is
         not present in the theme's i18n catalog — relying on `_()` would
         leave Arabic users with an English aria-label. Direction-based
         ternary covers the two languages this theme primarily serves.
         If you add the msgid to the catalog later, switch to `_()`. #}
      {% set _aria_label = 'تواصل عبر واتساب' if session.locale.language.direction == 'rtl' else 'Chat on WhatsApp' %}

      <a
        class="whatsapp-fab whatsapp-fab--{{ _position }}{% if _pulse %} whatsapp-fab--pulse{% endif %}"
        data-whatsapp-fab
        data-base-url="https://wa.me/{{ _digits }}"
        data-message="{{ _msg_base | e }}"
        data-append-url="{{ 'true' if settings.whatsapp_fab_append_url else 'false' }}"
        data-country="{{ _country_code }}"
        href="https://wa.me/{{ _digits }}{% if _msg_base | trim %}?text={{ _msg_base | urlencode }}{% endif %}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="{{ _aria_label }}"
        title="{{ _aria_label }}"
        style="--wa-x: {{ _offset_x }}px; --wa-y: {{ _offset_y }}px;"
      >
        {# Official WhatsApp glyph — same SVG path used in footer.jinja
           for visual consistency. #}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          width="28"
          height="28"
        >
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>

      {# Static styles live in `assets/css/components.css` (in @layer
         components — search for "WHATSAPP FLOATING BUTTON"). Only the
         per-render `--wa-x` / `--wa-y` offset variables are inlined on
         the anchor itself via the `style` attribute above. #}

      <script type="module">
        {
          const fab = document.querySelector("[data-whatsapp-fab]");
          if (fab) {
            // Append the page URL to the WhatsApp message at click time.
            // Done client-side (not in the static href) so the URL stays
            // accurate even when the page is served from cache. If
            // `data-append-url` is "false", we leave the static href.
            //
            // We listen on both `click` and `auxclick` so middle-click
            // (open-in-new-tab via mouse wheel) gets the same updated
            // href — without `auxclick` the middle-click path uses the
            // stale base URL without the page-URL append. Capture phase
            // fires before the browser commits the navigation.
            const updateHref = () => {
              if (fab.dataset.appendUrl !== "true") return;
              const base = fab.dataset.baseUrl;
              const baseMsg = fab.dataset.message || "";
              const sep = baseMsg ? "\n\n" : "";
              const fullMsg = `${baseMsg}${sep}${window.location.href}`;
              fab.href = `${base}?text=${encodeURIComponent(fullMsg)}`;
            };

            // dataLayer instrumentation — fires regardless of the
            // append-url toggle so merchants can track WhatsApp intent
            // by country/page even with the simpler URL config. We
            // create the array if GTM hasn't loaded yet so the event
            // queues for replay.
            const trackClick = () => {
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: "whatsapp_fab_click",
                country: fab.dataset.country || "",
                page_url: window.location.href,
                page_template: document.body?.dataset.template || ""
              });
            };

            const onActivate = () => { updateHref(); trackClick(); };
            fab.addEventListener("click", onActivate, { capture: true });
            fab.addEventListener("auxclick", onActivate, { capture: true });
          }
        }
      </script>
    {% endif %}
  {% endif %}
{% endif %}
