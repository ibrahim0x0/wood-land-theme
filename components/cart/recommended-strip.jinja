{# Recommended products strip — reusable on cart page and in the cart drawer #}
{% set _rec_enabled  = settings.cart_show_recommended | default(true) %}
{% set _rec_count    = settings.cart_recommended_count | default(8) %}
{% set _rec_strategy = settings.cart_recommended_strategy or 'latest' %}
{% set _rec_manual   = settings.cart_recommended_manual or '' %}
{% set _rec_cat      = settings.cart_recommended_category %}
{% set _rec_title    = settings.cart_recommended_title or _('You might also like') %}

{% if _rec_enabled %}
<div
  class="cart-rec-strip mt-8"
  data-cart-rec-strip
  data-strategy="{{ _rec_strategy }}"
  data-count="{{ _rec_count }}"
  data-manual="{{ _rec_manual }}"
  {% if _rec_cat and _rec_cat.id %}data-category="{{ _rec_cat.id }}"{% endif %}
  data-label-add="{{ _('Add') }}"
  data-label-added="{{ _('Added') }}"
  data-label-choose-option="{{ _('Choose option') }}"
>
  <h3 class="text-foreground text-lg font-semibold mb-1">{{ _rec_title }}</h3>
  <p class="text-muted mb-4 text-sm">{{ 'أضِفها لطلبك الآن قبل نفاد الكمية — اختارها عملاؤنا غالبًا مع طلبهم ✨' if (session.lang or '').startswith('ar') else 'Add them now before they sell out — customers often pair these with their order ✨' }}</p>

  <div class="cart-rec-strip__viewport">
    <div class="cart-rec-strip__track" data-cart-rec-track>
      {# Loading skeleton #}
      {% for i in range(4) %}
        <div class="cart-rec-strip__skeleton">
          <div class="bg-secondary aspect-[16/9] animate-pulse"></div>
          <div class="mt-2 space-y-1.5">
            <div class="bg-secondary h-3 w-3/4 animate-pulse"></div>
            <div class="bg-secondary h-3 w-1/2 animate-pulse"></div>
          </div>
        </div>
      {% endfor %}
    </div>

    {# Swipe hint — primary-coloured animated icon (matches the product rows).
       Shown/hidden by recommended-strip.js based on whether it overflows. #}
    <div class="cart-rec-strip__hint" data-cart-rec-hint aria-hidden="true">
      <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M30.509,7l-3.254,3.254l-0.51-0.509l2.386-2.386h-9.796c-0.096,1.677-0.844,3.254-2.102,4.37l-0.478-0.539c1.194-1.058,1.878-2.585,1.878-4.19c0-3.11-2.53-5.64-5.64-5.64S7.354,3.89,7.354,7c0,1.605,0.685,3.133,1.879,4.19l-0.478,0.539C7.407,10.535,6.634,8.811,6.634,7c0-3.507,2.853-6.36,6.36-6.36c3.385,0,6.154,2.661,6.342,6h9.795l-2.386-2.386l0.51-0.509L30.509,7z M26.36,18.776v4.01c0,4.453-1.041,8.574-8.591,8.574c-5.067,0-7.409-2.218-10.404-5.602c-0.844-0.953-3.435-3.76-3.435-3.76l-0.5-0.554c-1.217-1.339-1.79-2.018-1.79-2.459c0-0.541,0.374-1.022,1.052-1.357c1.188-0.586,3.129-0.646,4.319,0.269c0.895,0.688,2.677,2.611,3.629,3.663V7c0-1.388,0.968-2.357,2.354-2.36c0,0,0,0,0.001,0c0,0,0.001,0,0.003,0c0.001,0,0.002,0,0.003,0C14.391,4.643,15.36,5.612,15.36,7v7.64h6.552C24.448,14.64,26.36,16.418,26.36,18.776z M25.64,18.776c0-1.948-1.603-3.417-3.728-3.417H15c-0.199,0-0.36-0.161-0.36-0.36V7c0-0.98-0.66-1.639-1.642-1.64C12.019,5.361,11.36,6.02,11.36,7v15.5c0,0.149-0.092,0.283-0.232,0.337c-0.139,0.054-0.298,0.015-0.397-0.099c-0.03-0.033-2.983-3.368-4.158-4.271c-0.925-0.709-2.588-0.673-3.562-0.192c-0.413,0.203-0.65,0.463-0.65,0.711c0.057,0.274,1.063,1.38,1.603,1.975l0.502,0.556c0.002,0.002,2.595,2.811,3.44,3.767c2.865,3.236,5.099,5.357,9.865,5.357c6.532,0,7.87-3.14,7.87-7.854L25.64,18.776L25.64,18.776z" fill="currentColor"/>
      </svg>
    </div>
  </div>

  {# Dot indicators — built by recommended-strip.js after the cards render. #}
  <div class="cart-rec-strip__dots" data-cart-rec-dots aria-hidden="true"></div>
</div>

<style>
  .cart-rec-strip__viewport {
    position: relative;
  }
  .cart-rec-strip__track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.75rem;
    scroll-snap-type: none; /* free momentum (no forced snap) */
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  .cart-rec-strip__track::-webkit-scrollbar { display: none; }
  .cart-rec-strip__skeleton {
    flex: 0 0 150px;
  }
  .cart-rec-strip__card {
    flex: 0 0 150px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    background: var(--background);
    border: 1px solid color-mix(in srgb, var(--foreground) 8%, transparent);
    border-radius: 0; /* squared per request */
    overflow: hidden;
    transition: transform 250ms ease;
  }
  .cart-rec-strip__card:hover {
    transform: translateY(-2px);
    /* no shadow per request */
  }
  .cart-rec-strip__img {
    display: block;
    /* Square so the full product shows; white well + contain prevents the
       tall jars/jerry-cans from being cropped or over-zoomed on mobile. */
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #fff;
  }
  .cart-rec-strip__img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 6px;
    transition: transform 400ms ease;
  }
  .cart-rec-strip__card:hover .cart-rec-strip__img img { transform: scale(1.05); }
  .cart-rec-strip__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0.75rem;
    gap: 0.5rem;
  }
  .cart-rec-strip__name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--foreground);
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: calc(0.8125rem * 1.3 * 2);
  }
  .cart-rec-strip__name:hover { text-decoration: underline; }
  .cart-rec-strip__price { font-size: 0.8125rem; font-weight: 700; color: var(--foreground); }
  .cart-rec-strip__price-original { font-size: 0.7rem; color: var(--muted); text-decoration: line-through; }
  .cart-rec-strip__price-sale { color: #dc2626; }
  .cart-rec-strip__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    margin-top: auto;
    padding: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--primary-foreground);
    background: var(--primary);
    border: 0;
    border-radius: 0; /* squared per request */
    cursor: pointer;
    transition: opacity 180ms ease;
  }
  .cart-rec-strip__btn:hover { opacity: 0.9; }

  /* Swipe hint — primary-coloured animated icon, trailing edge, vertically
     centered over the strip. */
  .cart-rec-strip__hint {
    position: absolute;
    top: 50%;
    inset-inline-start: 0.25rem; /* physical right in RTL */
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    color: var(--primary);
    pointer-events: none;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
    opacity: 1;
    transition: opacity 300ms ease;
  }
  .cart-rec-strip__hint.is-hidden { opacity: 0; }
  .cart-rec-strip__hint svg {
    width: 1.6rem;
    height: 1.6rem;
    fill: currentColor;
    /* Animation disabled per request — the hand stays still. */
    animation: none;
  }
  @keyframes cart-rec-swipe {
    0%, 100% { transform: translateX(-5px); }
    50%      { transform: translateX(5px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .cart-rec-strip__hint svg { animation: none; }
  }

  /* Dot indicators (use the global .carousel-dot styling). */
  .cart-rec-strip__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }
</style>

{% endif %}
