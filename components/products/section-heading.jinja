{#
  Section Heading — shared partial
  --------------------------------
  Used by the Products section (homepage grid + carousel) and the
  standalone "Section Heading" block. Renders eyebrow + title + subtitle
  + optional "more" link. Visual variant is driven by `heading_style`
  via a `data-heading-style` attribute; CSS in product-card.css targets
  those attribute values to swap looks without changing markup.

  Props (all optional unless noted):
  - eyebrow             str  — short uppercase kicker above the title
  - title               str
  - subtitle            str
  - heading_alignment   'start' | 'center' | 'end'   (default 'start')
  - heading_size        'sm' | 'md' | 'lg'           (default 'md')
  - heading_style       'souq' | 'elite'             (default 'souq')
                                - souq:    bold title, icon leads inline
                                           (no bar — icon IS the anchor)
                                - elite:   thin kashida hairline under the
                                           title; icon doesn't affect layout
  - heading_icon        str  — URL to a decorative image. For souq it
                                renders INLINE on the leading edge of the
                                title row. For elite it's intentionally
                                ignored (the kashida is the identity).
  - more_url            str  — "see more" link href
  - more_text           str  — "see more" link label
  - more_class          str  — extra classes on the "more" anchor
#}

{% if title or subtitle or eyebrow %}
  {# Single heading style: ornate (centered title + line-and-ring divider).
     The old souq/elite variants were removed, so any saved value renders
     as ornate. #}
  {% set _heading_style = 'ornate' %}
  <div
    class="products-heading"
    data-heading-align="{{ heading_alignment | default('start') }}"
    data-heading-size="{{ heading_size | default('md') }}"
    data-heading-style="{{ _heading_style }}"
    {% if heading_icon and _heading_style == 'souq' %}data-heading-has-icon="true"{% endif %}
  >
    <div class="products-heading__text">
      {% if eyebrow %}
        <p class="products-heading__eyebrow">{{ eyebrow }}</p>
      {% endif %}

      {# Title row — carries an optional inline icon for the souq style so
         the icon becomes the leading anchor next to the bold title.
         Elite intentionally ignores the icon (its identity is the
         kashida hairline under the title). #}
      {# Icon + title share a row. For souq style, CSS pulls the icon out
         of the layout flow (position: absolute) so the row's width
         equals the title's width — this way the eyebrow, title, and
         subtitle all align to the title's edges, not the title+icon
         combined edges. The icon's side (leading vs trailing) flips
         based on alignment: hangs off the start edge for start/center,
         off the trailing edge for end. All done in CSS so the markup
         stays simple. #}
      {% if title or (heading_icon and _heading_style == 'souq') %}
        <div class="products-heading__title-row">
          {% if heading_icon and _heading_style == 'souq' %}
            <img
              src="{{ heading_icon }}"
              alt=""
              aria-hidden="true"
              class="products-heading__inline-icon"
              loading="lazy"
              decoding="async"
            />
          {% endif %}
          {% if title %}
            <h2 class="products-heading__title">{{ title }}</h2>
          {% endif %}
        </div>
      {% endif %}

      {# Ornate divider — explicit markup (two faded lines flanking a ring)
         so its layout is deterministic and always centered under the title. #}
      {% if title %}
        <span class="products-heading__divider" aria-hidden="true">
          <span class="products-heading__divider-line"></span>
          <span class="products-heading__divider-ring"></span>
          <span class="products-heading__divider-line"></span>
        </span>
      {% endif %}

      {% if subtitle %}
        <p class="products-heading__subtitle">{{ subtitle }}</p>
      {% endif %}
    </div>

    {% if more_url and more_text %}
      <a href="{{ more_url }}" class="products-heading__more{% if more_class %} {{ more_class }}{% endif %}">
        {{ more_text }}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="rtl:rotate-180" aria-hidden="true">
          <path d="M16.8917 12.8019H4.70224C4.45758 12.8019 4.25449 12.7211 4.09299 12.5594C3.93133 12.3977 3.85049 12.1946 3.85049 11.9501C3.85049 11.7056 3.93133 11.5026 4.09299 11.3409C4.25449 11.1792 4.45758 11.0984 4.70224 11.0984H16.8917L13.3592 7.55989C13.1892 7.39389 13.1084 7.19597 13.1167 6.96614C13.1251 6.73631 13.2142 6.53639 13.3842 6.36639C13.5502 6.20056 13.7472 6.11864 13.975 6.12064C14.2028 6.12247 14.4017 6.20639 14.5717 6.37239L19.5527 11.3474C19.6441 11.4387 19.7104 11.5341 19.7517 11.6334C19.7929 11.7326 19.8135 11.8381 19.8135 11.9501C19.8135 12.0621 19.7929 12.1677 19.7517 12.2669C19.7104 12.3662 19.6441 12.4616 19.5527 12.5529L14.5967 17.5029C14.4267 17.6689 14.2278 17.7528 14 17.7546C13.7722 17.7566 13.5752 17.6727 13.4092 17.5029C13.2392 17.3369 13.1542 17.1348 13.1542 16.8966C13.1542 16.6585 13.2392 16.4544 13.4092 16.2844L16.8917 12.8019Z" fill="currentColor"></path>
        </svg>
      </a>
    {% endif %}
  </div>
{% endif %}
