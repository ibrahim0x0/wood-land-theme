<div class="flex items-center justify-between gap-4">
  <div class="size-20 shrink-0 overflow-hidden rounded">
    <img
      src="{{ image_url(variant.images[0].image.medium, w=160, q=85, f='auto') if variant.images and variant.images | length > 0 else image_url(('images/placeholder-image.svg' | asset_url), w=160, q=85, f='auto') }}"
      alt="{{ variant.images[0].alt_text if variant.images and variant.images | length > 0 and variant.images[0].alt_text else variant.name }}"
      class="size-full object-cover"
    />
  </div>
  <div class="flex-1">
    <h3 class="text-foreground text-base font-semibold [font-variant:all-small-caps]">{{ variant.name }}</h3>
    <p class="text-muted text-sm mt-1 [font-variant:all-small-caps]">
      {% for attribute in variant.attributes %}
        {{ attribute.value }}{% if not loop.last %}â€¢{% endif %}
      {% endfor %}
    </p>
    <div class="mt-2 flex items-center gap-2">
      {% if variant.formatted_sale_price %}
        <span class="text-sm">{{ variant.formatted_sale_price }}</span>
        <span class="text-destructive text-sm line-through"> {{ variant.formatted_price }} </span>
      {% else %}
        <span class="text-sm">{{ variant.formatted_price }}</span>
      {% endif %}
    </div>
  </div>
</div>
