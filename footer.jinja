{# ───────────────────────────────────────────────────────────────────
   Footer

   Layout (top → bottom):
     1. Brand column        — logo, about-us, follow-us, social icons,
                              optional iOS/Android app store badges,
                              optional newsletter signup.
     2. Link groups (1-6)   — merchant-defined column lists. Render
                              as columns on desktop; collapse to
                              <details> accordions on mobile when
                              `mobile_accordion` is on.
     3. Contact info        — email + address + phone, sourced from
                              Vitrin's `store.settings.contact.*`
                              (platform-managed, not theme-config).
     4. Bottom strip        — copyright + grouped trust badges
                              (shipping methods, payment methods,
                              VAT cert, business center).

   URL safety: all merchant-supplied URLs (link groups, social
   custom links, newsletter action) pass through `safe_url` from
   `_macros.jinja` to defeat `javascript:` / `data:` schemes.

   Social icons: 5 primary platforms (Facebook/Instagram/X/
   Snapchat/TikTok) wired to `store.settings.contact.*`. Additional
   platforms via `settings.social_items` (LinkedIn/YouTube/Pinterest/
   WhatsApp/Threads/Telegram + custom). All icons defined ONCE as
   <symbol>s in a hidden SVG sprite at the top of the footer and
   referenced via <use> — saves ~3KB of repeated path data.
   ─────────────────────────────────────────────────────────────────── #}

{% from 'components/_macros.jinja' import safe_url, country_visible %}

{# ── Resolve settings up front so the body stays declarative ── #}
{% set logo_height       = settings.logo_logo_height if settings.logo_logo_height is not none else 44 %}
{% set bg                = settings.appearance_background    | default('secondary', true) %}
{% set mobile_accordion  = settings.appearance_mobile_accordion if settings.appearance_mobile_accordion is not none else true %}
{% set heading_size      = settings.appearance_heading_size   | default('sm', true) %}
{% set heading_weight    = settings.appearance_heading_weight | default('medium', true) %}
{% set frame_enabled     = settings.appearance_frame_enabled  if settings.appearance_frame_enabled  is not none else true %}
{% set frame_color       = (settings.appearance_frame_color | trim) if settings.appearance_frame_color else '' %}
{% set frame_radius      = settings.appearance_frame_radius   if settings.appearance_frame_radius   is not none else 24 %}
{% set tagline           = (settings.appearance_tagline | trim) if settings.appearance_tagline else '' %}
{% set col_align         = settings.appearance_column_alignment | default('start', true) %}

{% set newsletter_hide   = settings.newsletter_newsletter_hide if settings.newsletter_newsletter_hide is not none else true %}
{% set newsletter_title  = (settings.newsletter_newsletter_title       | trim) if settings.newsletter_newsletter_title else '' %}
{% set newsletter_desc   = (settings.newsletter_newsletter_description | trim) if settings.newsletter_newsletter_description else '' %}
{% set newsletter_ph     = (settings.newsletter_newsletter_placeholder | trim) if settings.newsletter_newsletter_placeholder else '' %}
{% set newsletter_btn    = (settings.newsletter_newsletter_button_label| trim) if settings.newsletter_newsletter_button_label else '' %}
{% set newsletter_action = safe_url((settings.newsletter_newsletter_action_url | trim) if settings.newsletter_newsletter_action_url else '') %}

{% set is_rtl = session.locale.language.direction == 'rtl' %}

{# ── Custom contact items + per-field visibility toggles ── #}
{% set contact_items          = settings.contact_info_items or [] %}
{% set show_email_field       = settings.contact_info_show_email if settings.contact_info_show_email is not none else true %}
{% set show_address_field     = settings.contact_info_show_address if settings.contact_info_show_address is not none else true %}
{% set show_phone_field       = settings.contact_info_show_phone if settings.contact_info_show_phone is not none else true %}
{% set show_instagram_handle  = settings.contact_info_show_instagram_handle if settings.contact_info_show_instagram_handle is not none else true %}

{# ── Working hours ── #}
{% set hours_display  = settings.hours_display %}
{% set hours_title    = (settings.hours_title | trim) if settings.hours_title else '' %}
{% set hours_position = settings.hours_position | default('contact_col', true) %}
{% set hours_lines    = settings.hours_lines or [] %}

{# ── Footer trust-strip (highlights above frame) ── #}
{% set fhl_display = settings.footer_highlights_display %}
{% set fhl_points  = settings.footer_highlights_points or [] %}
{% set fhl_style   = settings.footer_highlights_container_style | default('unified', true) %}

{# ── Country auto-detection ──
   Resolve the visitor's country from multiple sources, in priority:
     1. session.locale.country.code   — explicit locale country object
        (most authoritative; e.g., merchant's region picker on the
        storefront sets this)
     2. session.locale.code           — URL locale code "ar-SA" → "SA"
        (visitor switched storefronts via the URL like /ar-sa/)
     3. session.country               — IP/geolocation (the visitor's
        physical location, not necessarily the storefront they chose)
   Then match against the merchant's `countries_items` list with this
   fallback chain: exact match → is_default row → first row.
   Codes are uppercased + trimmed for case-insensitive matching. #}
{% set _all_countries = settings.countries_items or [] %}
{# Defensive locale parsing — try every reasonable property path
   Zid/Vitrin might expose for the storefront's country. Listed in
   priority order; first non-empty value wins.
     session.locale.country.code   — country object exposing .code
     session.locale.country        — country as a plain string
     session.locale.code           — locale code like "ar-SA" → split
     session.country_code          — direct country_code field
     session.country               — IP/geolocation fallback #}
{% set _locale_country_code = '' %}
{% if session.locale %}
  {% if session.locale.country and session.locale.country.code is defined %}
    {% set _locale_country_code = session.locale.country.code %}
  {% elif session.locale.country %}
    {# country might be a plain string instead of an object #}
    {% set _locale_country_code = session.locale.country %}
  {% endif %}
  {% if not _locale_country_code and session.locale.code and '-' in session.locale.code %}
    {% set _locale_country_code = session.locale.code.split('-')[1] %}
  {% endif %}
{% endif %}
{# Build the detected country from the same chain the country_visible
   macro uses — keeps both code paths in lock-step. Critical: read
   `session.country.code` (the OBJECT's .code property), not the
   bare `session.country` object — coercing the object to string
   produces a Python repr like "<Country>" that never matches a code. #}
{% set _ns_dc = namespace(cc=(_locale_country_code or '')) %}
{% if not _ns_dc.cc and request is defined and request and request.country %}
  {% set _ns_dc.cc = request.country %}
{% endif %}
{% if not _ns_dc.cc and session.country_code %}
  {% set _ns_dc.cc = session.country_code %}
{% endif %}
{% if not _ns_dc.cc and session.country and session.country.code is defined %}
  {% set _ns_dc.cc = session.country.code %}
{% endif %}
{% if not _ns_dc.cc and store is defined and store and store.country_code %}
  {% set _ns_dc.cc = store.country_code %}
{% endif %}
{% set _detected_country = (_ns_dc.cc | string | upper | trim) %}
{# Case-insensitive match against the merchant's country list — the
   merchant can type `sa`, `SA`, or `Sa` in the theme editor and we'll
   still match against the uppercased detected country. Jinja's
   `selectattr` does literal equality only, so we iterate with a
   namespace to capture the first match. #}
{% set _ns = namespace(matched=none) %}
{% if _detected_country %}
  {% for _c in _all_countries %}
    {% if not _ns.matched and _c.code and (_c.code | string | upper | trim) == _detected_country %}
      {% set _ns.matched = _c %}
    {% endif %}
  {% endfor %}
{% endif %}
{% set _country_matched = _ns.matched %}
{% set _country_default = _all_countries | selectattr('is_default', 'equalto', true) | first %}
{% set country_links_block = _country_matched or _country_default or (_all_countries | first) %}
{% set country_was_detected = _country_matched is not none %}
{% set country_show_hint = settings.countries_show_detection_hint %}
{% set country_show_on = settings.countries_show_on | default('always', true) %}

{# ── Cert logos row ── #}
{% set certs_display = settings.certs_display %}
{% set certs_title   = (settings.certs_title | trim) if settings.certs_title else '' %}
{% set certs_logos   = settings.certs_logos or [] %}
{% set certs_style   = settings.certs_style | default('grayscale', true) %}

{# ── Helper: clean a social handle ──
   If a merchant pastes a full URL (e.g. `https://facebook.com/myhandle`)
   into a Zid contact-handle field instead of just the handle, we'd
   otherwise produce `https://www.facebook.com/https://facebook.com/...`.
   Strip the scheme and known prefixes so concatenation stays clean. #}
{% macro normalize_handle(raw, prefix) %}
{%- set h = (raw | trim) if raw else '' -%}
{%- set h = h | replace('https://', '') | replace('http://', '') -%}
{%- if prefix -%}
{%- set h = h | replace(prefix, '') -%}
{%- endif -%}
{%- set h = h.lstrip('/') if h.startswith('/') else h -%}
{%- set h = h.lstrip('@') if h.startswith('@') else h -%}
{{- h -}}
{% endmacro %}

{# ── Working-hours block — rendered in either brand or contact column.
   Single macro called twice (with the position guard) keeps the markup
   in one place and the column-placement decision purely declarative. #}
{% macro render_hours() %}
  {% if hours_display and hours_lines %}
    <div class="footer-hours">
      <h3 class="footer-heading footer-hours__title">
        {{ hours_title or _("Working hours") }}
      </h3>
      <ul class="footer-hours__list" role="list">
        {% for line in hours_lines %}
          {% if line.label or line.value %}
            <li class="footer-hours__row">
              <span class="footer-hours__label">{{ line.label }}</span>
              <span class="footer-hours__value">{{ line.value }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  {% endif %}
{% endmacro %}

<footer
  id="footer"
  class="site-footer px-4 py-8 md:px-16 md:py-9"
  data-bg="{{ bg }}"
  data-heading-size="{{ heading_size }}"
  data-heading-weight="{{ heading_weight }}"
  data-col-align="{{ col_align }}"
  {% if frame_enabled %}data-framed="true"{% endif %}
  {% if mobile_accordion %}data-mobile-accordion="true"{% endif %}
  style="
    --footer-logo-height: {{ logo_height }}px;
    --footer-frame-radius: {{ frame_radius }}px;
    {% if frame_color %}--footer-frame-color: {{ frame_color }};{% endif %}
  "
>
  {# ── SVG sprite — all social icons defined once, referenced
     N times below via <use href="#footer-social-X">. Hidden via
     `display:none` on the wrapping <svg>. The viewBox values are
     each platform's standard logo box; some are 24×24, others
     differ (Snapchat is 512×512, etc.). #}
