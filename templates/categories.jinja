{% extends "layout.jinja" %}

{% block title %}{{ store.name }} – {{ _('All Categories') }}{% endblock %}

{% block content %}
  {# Hero Section #}
  {%
    with
    title=_("Explore Our Categories"),
    description=_("Browse our complete collection of products organized by category")
  %}
    {% include 'components/categories/category-hero.jinja' %}
  {% endwith %}

  {# Breadcrumb Section #}
  <section class="px-4 py-6 md:px-16">
    <div class="theme-container">
      {%
        with
        items=[
          {'href': url_for('home'), 'label': _("Home")},
          {'label': _("All Categories")}
        ]
      %}
        {% include 'components/ui/breadcrumb.jinja' %}
      {% endwith %}
    </div>
  </section>

  {# Main Categories Grid #}
  <section class="px-4 pb-16 md:px-16">
    <div class="theme-container">
      <div class="flex flex-col gap-6">
        {# Section Title #}
        <h2 class="text-foreground text-xl md:text-2xl font-semibold tracking-tight">{{ _("Shop by Categories") }}</h2>

        {# Categories list — names only (no image cards, no subcategory
           carousels). Each name is a bordered link into the category page. #}
        {% if categories and categories|length > 0 %}
          <div class="categories-name-grid">
            {% for category in categories %}
              <a
                href="{{ url_for('category_details', category_id=category.id, slug=category.slug) }}"
                class="category-name-link"
              >
                <span class="category-name-link__text">{{ category.name }}</span>
                <svg
                  class="category-name-link__chevron"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </a>
            {% endfor %}
          </div>
        {% else %}
          <div class="bg-secondary flex flex-col items-center justify-center rounded-lg py-16">
            <p class="text-muted text-sm">{{ _("No categories found") }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </section>

  <style>
    .categories-name-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }
    @media (min-width: 768px) {
      .categories-name-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
    .category-name-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 1rem 1.125rem;
      border: 1px solid var(--border-light, color-mix(in srgb, var(--foreground) 12%, transparent));
      border-radius: var(--button-radius);
      background: var(--background);
      color: var(--foreground);
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
      transition: border-color 160ms ease, background 160ms ease, color 160ms ease, transform 160ms ease;
    }
    .category-name-link:hover {
      border-color: var(--primary);
      background: color-mix(in srgb, var(--primary) 6%, transparent);
      color: var(--primary);
      transform: translateY(-1px);
    }
    .category-name-link__text {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .category-name-link__chevron {
      flex-shrink: 0;
      color: var(--muted);
    }
    .category-name-link:hover .category-name-link__chevron {
      color: var(--primary);
    }
    /* Chevron points toward the reading-forward direction in RTL. */
    [dir="rtl"] .category-name-link__chevron {
      transform: scaleX(-1);
    }
  </style>
{% endblock %}
