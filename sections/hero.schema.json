{
  "template": "sections/hero.jinja",
  "name": {
    "ar": "البانر الرئيسي",
    "en": "Hero Banner"
  },
  "settings": [
    {
      "id": "is_primary_hero",
      "type": "checkbox",
      "label": {
        "ar": "البانر الرئيسي (H1)",
        "en": "Primary hero (renders as H1)"
      },
      "info": {
        "ar": "يُعرض العنوان كـ H1. استخدم فقط على أول بانر في الصفحة لأغراض السيو.",
        "en": "Renders the heading as H1. Use ONLY on the first hero of the page for correct SEO."
      },
      "default": true
    },
    {
      "id": "background_image",
      "type": "image",
      "label": {
        "ar": "صورة الخلفية — سطح المكتب",
        "en": "Background image — Desktop"
      },
      "info": {
        "ar": "مقاس مقترح: 1920×1080. يُنصح بشدة بإضافتها حتى عند استخدام فيديو خلفية — تظهر فورًا كصورة معاينة (poster) للفيديو، وهي أساسية لسرعة التحميل (LCP).",
        "en": "Recommended: 1920×1080. Strongly recommended even when using a background video — it paints instantly as the video's poster and is critical for load speed (LCP)."
      }
    },
    {
      "id": "background_image_mobile",
      "type": "image",
      "label": {
        "ar": "صورة الخلفية — موبايل",
        "en": "Background image — Mobile"
      },
      "info": {
        "ar": "مقاس مقترح: 828×1200 (طولي).",
        "en": "Recommended: 828×1200 (portrait)."
      }
    },
    {
      "id": "background_video",
      "type": "video",
      "label": {
        "ar": "فيديو الخلفية — سطح المكتب (اختياري)",
        "en": "Background video — Desktop (optional)"
      },
      "info": {
        "ar": "MP4 فقط — الحد الأقصى 10MB. يُعرض مكتومًا بتكرار فوق الصورة.",
        "en": "MP4 only — 10MB max. Plays muted on loop over the background image."
      }
    },
    {
      "id": "background_video_mobile",
      "type": "video",
      "label": {
        "ar": "فيديو الخلفية — موبايل (اختياري)",
        "en": "Background video — Mobile (optional)"
      },
      "info": {
        "ar": "MP4 فقط — الحد الأقصى 10MB. إن تُرك فارغًا، يُستخدم فيديو سطح المكتب.",
        "en": "MP4 only — 10MB max. If empty, the desktop video is used on mobile too."
      }
    },
    {
      "id": "video_play_on_mobile",
      "type": "checkbox",
      "label": {
        "ar": "تشغيل الفيديو على الموبايل",
        "en": "Play video on mobile"
      },
      "info": {
        "ar": "بشكل افتراضي، يرى مستخدمو الموبايل الصورة فقط لتوفير البيانات.",
        "en": "Off by default — mobile visitors see the image only, saving data."
      },
      "default": false
    },
    {
      "id": "video_respect_motion",
      "type": "checkbox",
      "label": {
        "ar": "احترام تقليل الحركة (إمكانية الوصول)",
        "en": "Respect reduced motion (accessibility)"
      },
      "default": true
    },
    {
      "id": "background_position",
      "type": "select",
      "label": {
        "ar": "موضع الصورة",
        "en": "Image position"
      },
      "options": [
        {
          "value": "center",
          "label": {
            "ar": "وسط",
            "en": "Center"
          }
        },
        {
          "value": "top",
          "label": {
            "ar": "أعلى",
            "en": "Top"
          }
        },
        {
          "value": "bottom",
          "label": {
            "ar": "أسفل",
            "en": "Bottom"
          }
        }
      ],
      "default": "center"
    },
    {
      "id": "overlay_color",
      "type": "select",
      "label": {
        "ar": "لون الطبقة العلوية",
        "en": "Overlay color"
      },
      "info": {
        "ar": "أسود = أفضل لجعل النص الفاتح مقروءًا. تدرُّج = يتلاشى من شفاف أعلى إلى داكن أسفل. العلامة = لون الزر فوق الصورة. بدون = بدون طبقة.",
        "en": "Dark (black) best for legibility. Gradient fades transparent top → dark bottom. Brand = primary color tint. None = no overlay."
      },
      "options": [
        {
          "value": "dark",
          "label": {
            "ar": "أسود",
            "en": "Dark"
          }
        },
        {
          "value": "gradient",
          "label": {
            "ar": "تدرُّج من الأسفل",
            "en": "Gradient (bottom fade)"
          }
        },
        {
          "value": "primary",
          "label": {
            "ar": "لون العلامة التجارية",
            "en": "Brand"
          }
        },
        {
          "value": "none",
          "label": {
            "ar": "بدون",
            "en": "None"
          }
        }
      ],
      "default": "dark"
    },
    {
      "id": "overlay_opacity",
      "type": "range",
      "label": {
        "ar": "شفافية الطبقة (إذا كانت ≠ بدون)",
        "en": "Overlay opacity (when overlay ≠ none)"
      },
      "info": {
        "ar": "يطبَّق فقط عند اختيار طبقة (داكنة/أساسية/تدرج). يُتجاهل عند اختيار \"بدون\".",
        "en": "Applies only when overlay color is dark / primary / gradient. Ignored when set to \"None\"."
      },
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 35
    },
