{
  "template": "sections/countdown.jinja",
  "name": {
    "ar": "العد التنازلي",
    "en": "Countdown Timer"
  },
  "settings": [
    {
      "id": "badge_text",
      "type": "text",
      "label": {
        "ar": "نص الشارة",
        "en": "Badge Text"
      },
      "default": ""
    },
    {
      "id": "title",
      "type": "text",
      "label": {
        "ar": "العنوان",
        "en": "Title"
      },
      "default": ""
    },
    {
      "id": "description",
      "type": "textarea",
      "label": {
        "ar": "الوصف",
        "en": "Description"
      },
      "default": ""
    },
    {
      "id": "end_date",
      "type": "text",
      "label": {
        "ar": "تاريخ الانتهاء",
        "en": "End Date"
      },
      "info": {
        "ar": "الصيغة المطلوبة: YYYY-MM-DD (مثال: 2025-12-31)",
        "en": "Required format: YYYY-MM-DD (e.g., 2025-12-31)"
      },
      "default": ""
    },
    {
      "id": "button_text",
      "type": "text",
      "label": {
        "ar": "نص الزر",
        "en": "Button Text"
      },
      "default": ""
    },
    {
      "id": "button_shortcut",
      "type": "select",
      "label": {
        "ar": "وجهة الزر (اختصار سريع)",
        "en": "Button destination (quick shortcut)"
      },
      "info": {
        "ar": "اختصار لوجهات شائعة. يتجاوز القائمة الذكية والرابط المخصص أدناه.",
        "en": "Shortcut for common destinations. Overrides the smart picker and custom URL below."
      },
      "options": [
        {
          "value": "none",
          "label": {
            "ar": "— لا شيء —",
            "en": "— None —"
          }
        },
        {
          "value": "recent",
          "label": {
            "ar": "الأحدث",
            "en": "Recent products"
          }
        },
        {
          "value": "bestseller",
          "label": {
            "ar": "الأكثر شيوعًا",
            "en": "Bestsellers / Most sales"
          }
        },
        {
          "value": "on_sale",
          "label": {
            "ar": "العروض",
            "en": "On sale"
          }
        },
        {
          "value": "all",
          "label": {
            "ar": "كل المنتجات",
            "en": "All products"
          }
        }
      ],
      "default": "none"
    },
    {
      "id": "button_products",
      "type": "products",
      "label": {
        "ar": "أو قائمة ذكية (منتجات/فئة)",
        "en": "Or smart picker (products / category)"
      }
    },
    {
      "id": "button_url",
      "type": "url",
      "label": {
        "ar": "أو رابط مخصص",
        "en": "Or custom URL"
      },
      "default": ""
    },
    {
      "id": "background_image",
      "type": "image",
      "label": {
        "ar": "صورة الخلفية (سطح المكتب)",
        "en": "Background Image (Desktop)"
      },
      "info": {
        "ar": "ارفع صورة بحجم 1500 × 480 بكسل",
        "en": "Upload image 1500 × 480 pixels"
      }
    },
    {
      "id": "background_image_mobile",
      "type": "image",
      "label": {
        "ar": "صورة الخلفية (موبايل)",
        "en": "Background Image (Mobile)"
      },
      "info": {
        "ar": "ارفع صورة بحجم 414 × 480 بكسل",
        "en": "Upload image 414 × 480 pixels"
      }
    },
    {
      "id": "overlay_opacity",
      "type": "range",
      "label": {
        "ar": "شفافية الطبقة",
        "en": "Overlay Opacity"
      },
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 5
    },
    {
      "id": "visibility_countries",
      "type": "text",
      "label": {
        "ar": "── إظهار في دول محددة (اختياري)",
        "en": "── Show in specific countries (optional)"
      },
      "info": {
        "ar": "رموز الدول مفصولة بفاصلة (مثل: \"SA, KW, AE\"). اتركه فارغًا لإظهار القسم في كل الدول. الكشف يستخدم رابط المتجر (/ar-sa/, /ar-kw/) ثم session.country كاحتياطي. غير حساس لحالة الأحرف.",
        "en": "Comma-separated country codes (e.g. \"SA, KW, AE\"). Leave empty to show in all countries. Detection uses the storefront URL locale (/ar-sa/, /ar-kw/) first, then session.country as a fallback. Case-insensitive."
      },
      "default": ""
    },
    {
      "id": "visibility_mode",
      "type": "select",
      "label": {
        "ar": "── وضع الاستهداف",
        "en": "── Targeting mode"
      },
      "info": {
        "ar": "إظهار في: يظهر القسم فقط للزوار من الدول المحددة. إخفاء في: يخفى القسم عن الزوار من الدول المحددة. يعمل فقط عند تعبئة قائمة الدول أعلاه.",
        "en": "Show in: section renders only for visitors from the listed countries. Hide in: section hides from visitors in the listed countries. Only takes effect when the country list above has values."
      },
      "options": [
        {
          "value": "show_in",
          "label": {
            "ar": "إظهار في الدول المحددة (افتراضي)",
            "en": "Show in listed countries (default)"
          }
        },
        {
          "value": "hide_in",
          "label": {
            "ar": "إخفاء في الدول المحددة",
            "en": "Hide in listed countries"
          }
        }
      ],
      "default": "show_in"
    }
  ]
}
