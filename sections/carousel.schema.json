{
  "template": "sections/carousel.jinja",
  "name": {
    "ar": "دوّار الصور",
    "en": "Image Carousel"
  },
  "settings": [
    {
      "id": "style_variant",
      "type": "select",
      "label": {
        "ar": "نمط العرض",
        "en": "Style Variant"
      },
      "options": [
        {
          "value": "default",
          "label": {
            "ar": "افتراضي",
            "en": "Default"
          }
        },
        {
          "value": "compact",
          "label": {
            "ar": "مضغوط",
            "en": "Compact"
          }
        }
      ],
      "default": "default"
    },
    {
      "id": "min_height_mobile",
      "type": "range",
      "label": {
        "ar": "الحد الأدنى للارتفاع (موبايل)",
        "en": "Minimum Height (Mobile)"
      },
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "id": "min_height_desktop",
      "type": "range",
      "label": {
        "ar": "الحد الأدنى للارتفاع (سطح المكتب)",
        "en": "Minimum Height (Desktop)"
      },
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "id": "transition_effect",
      "type": "select",
      "label": {
        "ar": "تأثير الانتقال",
        "en": "Transition Effect"
      },
      "options": [
        {
          "value": "fade",
          "label": {
            "ar": "تلاشي",
            "en": "Fade"
          }
        },
        {
          "value": "slide",
          "label": {
            "ar": "انزلاق",
            "en": "Slide"
          }
        }
      ],
      "default": "fade"
    },
    {
      "id": "autoplay_enabled",
      "type": "checkbox",
      "label": {
        "ar": "تشغيل تلقائي",
        "en": "Enable Autoplay"
      },
      "default": true
    },
    {
      "id": "autoplay_delay",
      "type": "range",
      "label": {
        "ar": "تأخير التشغيل التلقائي",
        "en": "Autoplay Delay"
      },
      "min": 2000,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "default": 4000,
      "visible_if": {
        "autoplay_enabled": true
      }
    },
    {
      "id": "show_dots",
      "type": "checkbox",
      "label": {
        "ar": "إظهار النقاط",
        "en": "Show Dots"
      },
      "default": true
    },
    {
      "id": "slides",
      "type": "list",
      "label": {
        "ar": "الشرائح",
        "en": "Slides"
      },
      "max_items": 5,
      "settings": [
        {
          "id": "background_image",
          "type": "image",
          "label": {
            "ar": "صورة الخلفية (سطح المكتب)",
            "en": "Background Image (Desktop)"
          },
          "info": {
            "ar": "ارفع صورة بحجم 1500 × 700 بكسل",
            "en": "Upload image 1500 × 700 pixels"
          }
        },
        {
          "id": "background_image_mobile",
          "type": "image",
          "label": {
            "ar": "صورة الخلفية (موبايل)",
            "en": "Background Image (Mobile)"
          },
          "info": {
            "ar": "ارفع صورة بحجم 414 × 700 بكسل",
            "en": "Upload image 414 × 700 pixels"
          }
        },
        {
          "id": "background_position",
          "type": "select",
          "label": {
            "ar": "موضع الخلفية",
            "en": "Background Position"
          },
          "options": [
            {
              "value": "center",
              "label": {
                "ar": "وسط",
                "en": "Center"
              }
            },
            {
              "value": "top",
              "label": {
                "ar": "أعلى",
                "en": "Top"
              }
            },
            {
              "value": "bottom",
              "label": {
                "ar": "أسفل",
                "en": "Bottom"
              }
            }
          ],
          "default": "center"
        },
        {
          "id": "overlay_opacity",
          "type": "range",
          "label": {
            "ar": "شفافية الطبقة",
            "en": "Overlay Opacity"
          },
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 20
        },
        {
          "id": "text_alignment",
          "type": "select",
          "label": {
            "ar": "محاذاة النص",
            "en": "Text Alignment"
          },
          "options": [
            {
              "value": "start",
              "label": {
                "ar": "البداية",
                "en": "Start"
              }
            },
            {
              "value": "center",
              "label": {
                "ar": "وسط",
                "en": "Center"
              }
            },
            {
              "value": "end",
              "label": {
                "ar": "النهاية",
                "en": "End"
              }
            }
          ],
          "default": "start"
        },
        {
          "id": "badge_text",
          "type": "text",
          "label": {
            "ar": "نص الشارة",
            "en": "Badge Text"
          },
          "default": "NEW COLLECTION"
        },
        {
          "id": "heading",
          "type": "text",
          "label": {
            "ar": "العنوان الرئيسي",
            "en": "Heading"
          },
          "default": "Superbloom 2025"
        },
        {
          "id": "description",
          "type": "textarea",
          "label": {
            "ar": "الوصف",
            "en": "Description"
          },
          "default": "Step into the season with flowing silhouettes and effortless elegance."
        },
        {
          "id": "button_text",
          "type": "text",
          "label": {
            "ar": "نص الزر",
            "en": "Button Text"
          },
          "default": "Shop the Collection"
        },
        {
          "id": "button_shortcut",
          "type": "select",
          "label": {
            "ar": "وجهة الزر (اختصار سريع)",
            "en": "Button destination (quick shortcut)"
          },
          "info": {
            "ar": "اختصار لوجهات شائعة. يتجاوز القائمة الذكية والرابط المخصص أدناه.",
            "en": "Shortcut for common destinations. Overrides the smart picker and custom URL below."
          },
          "options": [
            {
              "value": "none",
              "label": {
                "ar": "— لا شيء —",
                "en": "— None —"
              }
            },
            {
              "value": "recent",
              "label": {
                "ar": "الأحدث",
                "en": "Recent products"
              }
            },
            {
              "value": "bestseller",
              "label": {
                "ar": "الأكثر شيوعًا",
                "en": "Bestsellers / Most sales"
              }
            },
            {
              "value": "on_sale",
              "label": {
                "ar": "العروض",
                "en": "On sale"
              }
            },
            {
              "value": "all",
              "label": {
                "ar": "كل المنتجات",
                "en": "All products"
              }
            }
          ],
          "default": "none"
        },
        {
          "id": "button_products",
          "type": "products",
          "label": {
            "ar": "أو قائمة ذكية (منتجات/فئة)",
            "en": "Or smart picker (products / category)"
          }
        },
        {
          "id": "button_url",
          "type": "url",
          "label": {
            "ar": "أو رابط مخصص",
            "en": "Or custom URL"
          },
          "default": ""
        }
      ]
    },
    {
      "id": "visibility_countries",
      "type": "text",
      "label": {
        "ar": "── إظهار في دول محددة (اختياري)",
        "en": "── Show in specific countries (optional)"
      },
      "info": {
        "ar": "رموز الدول مفصولة بفاصلة (مثل: \"SA, KW, AE\"). اتركه فارغًا لإظهار القسم في كل الدول. الكشف يستخدم رابط المتجر (/ar-sa/, /ar-kw/) ثم session.country كاحتياطي. غير حساس لحالة الأحرف.",
        "en": "Comma-separated country codes (e.g. \"SA, KW, AE\"). Leave empty to show in all countries. Detection uses the storefront URL locale (/ar-sa/, /ar-kw/) first, then session.country as a fallback. Case-insensitive."
      },
      "default": ""
    },
    {
      "id": "visibility_mode",
      "type": "select",
      "label": {
        "ar": "── وضع الاستهداف",
        "en": "── Targeting mode"
      },
      "info": {
        "ar": "إظهار في: يظهر القسم فقط للزوار من الدول المحددة. إخفاء في: يخفى القسم عن الزوار من الدول المحددة. يعمل فقط عند تعبئة قائمة الدول أعلاه.",
        "en": "Show in: section renders only for visitors from the listed countries. Hide in: section hides from visitors in the listed countries. Only takes effect when the country list above has values."
      },
      "options": [
        {
          "value": "show_in",
          "label": {
            "ar": "إظهار في الدول المحددة (افتراضي)",
            "en": "Show in listed countries (default)"
          }
        },
        {
          "value": "hide_in",
          "label": {
            "ar": "إخفاء في الدول المحددة",
            "en": "Hide in listed countries"
          }
        }
      ],
      "default": "show_in"
    }
  ]
}
