{
  "template": "sections/marquee.jinja",
  "name": {
    "ar": "شريط متحرك",
    "en": "Marquee"
  },
  "settings": [
    {
      "id": "entries",
      "type": "list",
      "label": {
        "ar": "العناصر",
        "en": "Items"
      },
      "info": {
        "ar": "أضف 4 عناصر فأكثر للحصول على شريط متواصل دون فجوات. كل عنصر يدعم نص و/أو صورة و/أو رابط.",
        "en": "Add 4+ items so the marquee feels continuous without gaps. Each item can have text, an image, a link, or any combination."
      },
      "max_items": 20,
      "settings": [
        {
          "id": "image",
          "type": "image",
          "label": {
            "ar": "الصورة (اختيارية)",
            "en": "Image (optional)"
          },
          "info": {
            "ar": "ارفع SVG أو PNG شفاف. الارتفاع موحّد عبر إعداد \"ارتفاع الصورة\" أدناه.",
            "en": "Upload an SVG or transparent PNG. Height is normalized via the 'Image height' setting below."
          }
        },
        {
          "id": "text",
          "type": "text",
          "label": {
            "ar": "النص",
            "en": "Text"
          }
        },
        {
          "id": "url",
          "type": "url",
          "label": {
            "ar": "الرابط (اختياري)",
            "en": "Link (optional)"
          }
        }
      ]
    },
    {
      "id": "speed",
      "type": "range",
      "label": {
        "ar": "السرعة",
        "en": "Speed"
      },
      "info": {
        "ar": "السرعة بالبكسل/الإطار. 0.5 = هادئ جداً، 1 = هادئ، 2 = متوسط، 3 = سريع. السرعة ثابتة بغض النظر عن عدد العناصر — المحرّك يضبط نفسه تلقائياً للأشرطة الأقصر أو الأطول.",
        "en": "Pixels per frame. 0.5 = very gentle, 1 = gentle, 2 = moderate, 3 = fast. Speed stays constant regardless of how many items you add — the engine adjusts automatically for shorter or longer strips."
      },
      "min": 0.25,
      "max": 4,
      "step": 0.25,
      "unit": "×",
      "default": 1
    },
    {
      "id": "direction",
      "type": "select",
      "label": {
        "ar": "الاتجاه",
        "en": "Direction"
      },
      "info": {
        "ar": "تلقائي: في LTR يتحرك يمين→يسار، في RTL يتحرك يسار→يمين (الاتجاه الطبيعي للقراءة).",
        "en": "Auto: LTR scrolls right→left, RTL scrolls left→right (natural reading direction)."
      },
      "options": [
        {
          "value": "auto",
          "label": {
            "ar": "تلقائي (حسب اتجاه اللغة)",
            "en": "Auto (follows page direction)"
          }
        },
        {
          "value": "reverse",
          "label": {
            "ar": "عكسي",
            "en": "Reverse"
          }
        }
      ],
      "default": "auto"
    },
    {
      "id": "pause_on_hover",
      "type": "checkbox",
      "label": {
        "ar": "إيقاف الحركة عند المرور بالمؤشر",
        "en": "Pause on hover"
      },
      "default": true
    },
    {
      "id": "edge_fade",
      "type": "checkbox",
      "label": {
        "ar": "تلاشي ناعم على الحواف",
        "en": "Soft fade at edges"
      },
      "info": {
        "ar": "بدلاً من قطع مفاجئ يبدو الشريط كأنه يتلاشى تدريجياً عند الحواف.",
        "en": "Instead of a hard cut at the edges, items fade in/out smoothly."
      },
      "default": true
    },
    {
      "id": "gap",
      "type": "range",
      "label": {
        "ar": "── المسافة بين العناصر",
        "en": "── Gap between items"
      },
      "min": 8,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "id": "image_height",
      "type": "range",
      "label": {
        "ar": "── ارتفاع الصورة",
        "en": "── Image height"
      },
      "min": 16,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "id": "image_max_width",
      "type": "range",
      "label": {
        "ar": "── أقصى عرض للصورة",
        "en": "── Image max width"
      },
      "info": {
        "ar": "يمنع الشعارات العريضة (مستطيلة) من الهيمنة على الشريط. اضبط على 0 لإلغاء الحد وترك العرض تلقائياً حسب الارتفاع.",
        "en": "Caps wide (banner-shaped) logos so they don't dominate the row. Set to 0 to remove the cap and let width follow the natural aspect ratio."
      },
      "min": 0,
      "max": 240,
      "step": 8,
      "unit": "px",
      "default": 120
    },
    {
      "id": "text_size",
      "type": "select",
      "label": {
        "ar": "── حجم النص",
        "en": "── Text size"
      },
      "options": [
        {
          "value": "sm",
          "label": {
            "ar": "صغير",
            "en": "Small"
          }
        },
        {
          "value": "md",
          "label": {
            "ar": "متوسط",
            "en": "Medium"
          }
        },
        {
          "value": "lg",
          "label": {
            "ar": "كبير",
            "en": "Large"
          }
        },
        {
          "value": "xl",
          "label": {
            "ar": "كبير جداً",
            "en": "Extra large"
          }
        }
      ],
      "default": "md"
    },
    {
      "id": "text_weight",
      "type": "select",
      "label": {
        "ar": "── سُمك الخط",
        "en": "── Font weight"
      },
      "options": [
        {
          "value": "regular",
          "label": {
            "ar": "عادي",
            "en": "Regular"
          }
        },
        {
          "value": "medium",
          "label": {
            "ar": "متوسط",
            "en": "Medium"
          }
        },
        {
          "value": "semibold",
          "label": {
            "ar": "نصف ثقيل",
            "en": "Semibold"
          }
        },
        {
          "value": "bold",
          "label": {
            "ar": "ثقيل",
            "en": "Bold"
          }
        }
      ],
      "default": "medium"
    },
    {
      "id": "text_color",
      "type": "select",
      "label": {
        "ar": "── لون النص",
        "en": "── Text color"
      },
      "options": [
        {
          "value": "auto",
          "label": {
            "ar": "تلقائي (يتباين مع الخلفية)",
            "en": "Auto (contrasts with background)"
          }
        },
        {
          "value": "foreground",
          "label": {
            "ar": "النص الأساسي",
            "en": "Foreground"
          }
        },
        {
          "value": "primary",
          "label": {
            "ar": "اللون الأساسي للعلامة",
            "en": "Primary brand color"
          }
        },
        {
          "value": "primary_foreground",
          "label": {
            "ar": "نص على الأساسي",
            "en": "Primary foreground"
          }
        },
        {
          "value": "muted",
          "label": {
            "ar": "خافت",
            "en": "Muted"
          }
        }
      ],
      "default": "auto"
    },
    {
      "id": "background",
      "type": "select",
      "label": {
        "ar": "── الخلفية",
        "en": "── Background"
      },
      "options": [
        {
          "value": "background",
          "label": {
            "ar": "خلفية الصفحة",
            "en": "Page background"
          }
        },
        {
          "value": "secondary",
          "label": {
            "ar": "ثانوي",
            "en": "Secondary"
          }
        },
        {
          "value": "primary",
          "label": {
            "ar": "اللون الأساسي للعلامة",
            "en": "Primary brand color"
          }
        },
        {
          "value": "foreground",
          "label": {
            "ar": "اللون الداكن (نص)",
            "en": "Foreground (dark)"
          }
        },
        {
          "value": "transparent",
          "label": {
            "ar": "شفاف",
            "en": "Transparent"
          }
        }
      ],
      "default": "primary"
    },
    {
      "id": "full_width",
      "type": "checkbox",
      "label": {
        "ar": "── عرض كامل (حافة إلى حافة)",
        "en": "── Full width (edge-to-edge)"
      },
      "info": {
        "ar": "عند التفعيل، الشريط يمتد حتى حواف الصفحة بدون حاوية. مناسب لشريط الأخبار العلوي / الأشرطة الإعلانية الكاملة. عند الإيقاف (افتراضي) يتم احتواؤه ضمن العرض القياسي للقالب (1440 بكسل).",
        "en": "When enabled, the strip stretches edge-to-edge with no container. Suits top news tickers and full-bleed promo bars. When off (default), it's contained within the theme's standard 1440px width like other sections."
      },
      "default": false
    },
    {
      "id": "padding_y",
      "type": "range",
      "label": {
        "ar": "── المسافة العمودية الداخلية",
        "en": "── Vertical padding (inside)"
      },
      "min": 0,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "id": "margin_y",
      "type": "range",
      "label": {
        "ar": "── المسافة العمودية الخارجية",
        "en": "── Vertical margin (outside)"
      },
      "min": 0,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "id": "border_top",
      "type": "checkbox",
      "label": {
        "ar": "── حد علوي",
        "en": "── Top border"
      },
      "default": false
    },
    {
      "id": "border_bottom",
      "type": "checkbox",
      "label": {
        "ar": "── حد سفلي",
        "en": "── Bottom border"
      },
      "default": false
    },
    {
      "id": "border_radius",
      "type": "range",
      "label": {
        "ar": "── نصف قطر الزوايا",
        "en": "── Corner radius"
      },
      "info": {
        "ar": "0 = شريط بعرض كامل بدون حواف. أعلى من 0 = شريط على شكل حاوية مدورة.",
        "en": "0 = edge-to-edge bar. Above 0 = inset rounded container."
      },
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "id": "visibility_countries",
      "type": "text",
      "label": {
        "ar": "── إظهار في دول محددة (اختياري)",
        "en": "── Show in specific countries (optional)"
      },
      "info": {
        "ar": "رموز الدول مفصولة بفاصلة (مثل: \"SA, KW, AE\"). اتركه فارغًا لإظهار القسم في كل الدول. الكشف يستخدم رابط المتجر (/ar-sa/, /ar-kw/) ثم session.country كاحتياطي. غير حساس لحالة الأحرف.",
        "en": "Comma-separated country codes (e.g. \"SA, KW, AE\"). Leave empty to show in all countries. Detection uses the storefront URL locale (/ar-sa/, /ar-kw/) first, then session.country as a fallback. Case-insensitive."
      },
      "default": ""
    },
    {
      "id": "visibility_mode",
      "type": "select",
      "label": {
        "ar": "── وضع الاستهداف",
        "en": "── Targeting mode"
      },
      "info": {
        "ar": "إظهار في: يظهر القسم فقط للزوار من الدول المحددة. إخفاء في: يخفى القسم عن الزوار من الدول المحددة. يعمل فقط عند تعبئة قائمة الدول أعلاه.",
        "en": "Show in: section renders only for visitors from the listed countries. Hide in: section hides from visitors in the listed countries. Only takes effect when the country list above has values."
      },
      "options": [
        {
          "value": "show_in",
          "label": {
            "ar": "إظهار في الدول المحددة (افتراضي)",
            "en": "Show in listed countries (default)"
          }
        },
        {
          "value": "hide_in",
          "label": {
            "ar": "إخفاء في الدول المحددة",
            "en": "Hide in listed countries"
          }
        }
      ],
      "default": "show_in"
    }
  ]
}
