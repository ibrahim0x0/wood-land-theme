{
  "template": "sections/gallery.jinja",
  "name": {
    "ar": "معرض الصور",
    "en": "Gallery"
  },
  "settings": [
    {
      "id": "eyebrow",
      "type": "text",
      "label": {
        "ar": "النص الافتتاحي (اختياري)",
        "en": "Eyebrow (optional)"
      },
      "info": {
        "ar": "سطر قصير فوق العنوان يظهر بحروف كبيرة بلون العلامة التجارية.",
        "en": "Short kicker line above the title, uppercase in the brand color."
      },
      "default": ""
    },
    {
      "id": "title",
      "type": "text",
      "label": {
        "ar": "العنوان",
        "en": "Title"
      },
      "default": ""
    },
    {
      "id": "subtitle",
      "type": "textarea",
      "label": {
        "ar": "الوصف (اختياري)",
        "en": "Subtitle (optional)"
      },
      "default": ""
    },

    {
      "id": "gallery",
      "type": "list",
      "label": {
        "ar": "الصور",
        "en": "Images"
      },
      "max_items": 8,
      "settings": [
        {
          "id": "src",
          "type": "image",
          "label": {
            "ar": "الصورة (سطح المكتب)",
            "en": "Image (Desktop)"
          },
          "info": {
            "ar": "ارفع صورة بحجم 650 × 650 بكسل",
            "en": "Upload image 650 × 650 pixels"
          }
        },
        {
          "id": "src_mobile",
          "type": "image",
          "label": {
            "ar": "الصورة (موبايل)",
            "en": "Image (Mobile)"
          },
          "info": {
            "ar": "ارفع صورة بحجم 650 × 650 بكسل",
            "en": "Upload image 650 × 650 pixels"
          }
        },
        {
          "id": "alt",
          "type": "text",
          "label": {
            "ar": "النص البديل للصورة",
            "en": "Image alt text"
          }
        },
        {
          "id": "image_title",
          "type": "text",
          "label": {
            "ar": "عنوان الصورة",
            "en": "Image title"
          }
        },
        {
          "id": "primary_button_text",
          "type": "text",
          "label": {
            "ar": "نص الزر الأساسي",
            "en": "Primary button text"
          }
        },
        {
          "id": "primary_button_shortcut",
          "type": "select",
          "label": {
            "ar": "وجهة الزر الأساسي (اختصار)",
            "en": "Primary button destination (shortcut)"
          },
          "info": {
            "ar": "اختصار لوجهات شائعة. يتجاوز القائمة الذكية والرابط المخصص أدناه.",
            "en": "Shortcut for common destinations. Overrides the smart picker and custom URL below."
          },
          "options": [
            {
              "value": "none",
              "label": {
                "ar": "— لا شيء —",
                "en": "— None —"
              }
            },
            {
              "value": "recent",
              "label": {
                "ar": "الأحدث",
                "en": "Recent products"
              }
            },
            {
              "value": "bestseller",
              "label": {
                "ar": "الأكثر شيوعًا",
                "en": "Bestsellers / Most sales"
              }
            },
            {
              "value": "on_sale",
              "label": {
                "ar": "العروض",
                "en": "On sale"
              }
            },
            {
              "value": "all",
              "label": {
                "ar": "كل المنتجات",
                "en": "All products"
              }
            }
          ],
          "default": "none"
        },
        {
          "id": "primary_button_products",
          "type": "products",
          "label": {
            "ar": "أو قائمة ذكية",
            "en": "Or smart picker"
          }
        },
        {
          "id": "primary_button_url",
          "type": "url",
          "label": {
            "ar": "أو رابط مخصص",
            "en": "Or custom URL"
          }
        },
        {
          "id": "secondary_button_text",
          "type": "text",
          "label": {
            "ar": "نص الزر الثانوي",
            "en": "Secondary button text"
          }
        },
        {
          "id": "secondary_button_shortcut",
          "type": "select",
          "label": {
            "ar": "وجهة الزر الثانوي (اختصار)",
            "en": "Secondary button destination (shortcut)"
          },
          "options": [
            {
              "value": "none",
              "label": {
                "ar": "— لا شيء —",
                "en": "— None —"
              }
            },
            {
              "value": "recent",
              "label": {
                "ar": "الأحدث",
                "en": "Recent products"
              }
            },
            {
              "value": "bestseller",
              "label": {
                "ar": "الأكثر شيوعًا",
                "en": "Bestsellers / Most sales"
              }
            },
            {
              "value": "on_sale",
              "label": {
                "ar": "العروض",
                "en": "On sale"
              }
            },
            {
              "value": "all",
              "label": {
                "ar": "كل المنتجات",
                "en": "All products"
              }
            }
          ],
          "default": "none"
        },
        {
          "id": "secondary_button_products",
          "type": "products",
          "label": {
            "ar": "أو قائمة ذكية",
            "en": "Or smart picker"
          }
        },
        {
          "id": "secondary_button_url",
          "type": "url",
          "label": {
            "ar": "أو رابط مخصص",
            "en": "Or custom URL"
          }
        }
      ]
    },
    {
      "id": "visibility_countries",
      "type": "text",
      "label": {
        "ar": "── إظهار في دول محددة (اختياري)",
        "en": "── Show in specific countries (optional)"
      },
      "info": {
        "ar": "رموز الدول مفصولة بفاصلة (مثل: \"SA, KW, AE\"). اتركه فارغًا لإظهار القسم في كل الدول. الكشف يستخدم رابط المتجر (/ar-sa/, /ar-kw/) ثم session.country كاحتياطي. غير حساس لحالة الأحرف.",
        "en": "Comma-separated country codes (e.g. \"SA, KW, AE\"). Leave empty to show in all countries. Detection uses the storefront URL locale (/ar-sa/, /ar-kw/) first, then session.country as a fallback. Case-insensitive."
      },
      "default": ""
    },
    {
      "id": "visibility_mode",
      "type": "select",
      "label": {
        "ar": "── وضع الاستهداف",
        "en": "── Targeting mode"
      },
      "info": {
        "ar": "إظهار في: يظهر القسم فقط للزوار من الدول المحددة. إخفاء في: يخفى القسم عن الزوار من الدول المحددة. يعمل فقط عند تعبئة قائمة الدول أعلاه.",
        "en": "Show in: section renders only for visitors from the listed countries. Hide in: section hides from visitors in the listed countries. Only takes effect when the country list above has values."
      },
      "options": [
        {
          "value": "show_in",
          "label": {
            "ar": "إظهار في الدول المحددة (افتراضي)",
            "en": "Show in listed countries (default)"
          }
        },
        {
          "value": "hide_in",
          "label": {
            "ar": "إخفاء في الدول المحددة",
            "en": "Hide in listed countries"
          }
        }
      ],
      "default": "show_in"
    }
  ]
}
