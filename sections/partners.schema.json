{
  "template": "sections/partners.jinja",
  "name": {
    "ar": "شركائنا",
    "en": "Partners"
  },
  "settings": [
    {
      "id": "eyebrow",
      "type": "text",
      "label": {
        "ar": "النص الافتتاحي (اختياري)",
        "en": "Eyebrow (optional)"
      },
      "info": {
        "ar": "سطر قصير فوق العنوان يظهر بحروف كبيرة بلون العلامة التجارية.",
        "en": "Short kicker line above the title, uppercase in the brand color."
      },
      "default": ""
    },
    {
      "id": "title",
      "type": "text",
      "label": {
        "ar": "العنوان",
        "en": "Title"
      },
      "default": "Our Partners"
    },
    {
      "id": "subtitle",
      "type": "textarea",
      "label": {
        "ar": "الوصف (اختياري)",
        "en": "Subtitle (optional)"
      },
      "default": ""
    },

    {
      "id": "store_partners",
      "type": "list",
      "label": {
        "ar": "الشركاء",
        "en": "Partners"
      },
      "max_items": 20,
      "settings": [
        {
          "id": "image",
          "type": "image",
          "label": {
            "ar": "الصورة (سطح المكتب)",
            "en": "Image (Desktop)"
          }
        },
        {
          "id": "image_mobile",
          "type": "image",
          "label": {
            "ar": "الصورة (موبايل)",
            "en": "Image (Mobile)"
          },
          "info": {
            "ar": "اختياري - يستخدم صورة سطح المكتب إذا لم يتم تحديده",
            "en": "Optional - Falls back to desktop image"
          }
        },
        {
          "id": "url",
          "type": "url",
          "label": {
            "ar": "الرابط",
            "en": "Link"
          }
        },
        {
          "id": "name",
          "type": "text",
          "label": {
            "ar": "اسم الشريك",
            "en": "Partner Name"
          }
        }
      ]
    },
    {
      "id": "visibility_countries",
      "type": "text",
      "label": {
        "ar": "── إظهار في دول محددة (اختياري)",
        "en": "── Show in specific countries (optional)"
      },
      "info": {
        "ar": "رموز الدول مفصولة بفاصلة (مثل: \"SA, KW, AE\"). اتركه فارغًا لإظهار القسم في كل الدول. الكشف يستخدم رابط المتجر (/ar-sa/, /ar-kw/) ثم session.country كاحتياطي. غير حساس لحالة الأحرف.",
        "en": "Comma-separated country codes (e.g. \"SA, KW, AE\"). Leave empty to show in all countries. Detection uses the storefront URL locale (/ar-sa/, /ar-kw/) first, then session.country as a fallback. Case-insensitive."
      },
      "default": ""
    },
    {
      "id": "visibility_mode",
      "type": "select",
      "label": {
        "ar": "── وضع الاستهداف",
        "en": "── Targeting mode"
      },
      "info": {
        "ar": "إظهار في: يظهر القسم فقط للزوار من الدول المحددة. إخفاء في: يخفى القسم عن الزوار من الدول المحددة. يعمل فقط عند تعبئة قائمة الدول أعلاه.",
        "en": "Show in: section renders only for visitors from the listed countries. Hide in: section hides from visitors in the listed countries. Only takes effect when the country list above has values."
      },
      "options": [
        {
          "value": "show_in",
          "label": {
            "ar": "إظهار في الدول المحددة (افتراضي)",
            "en": "Show in listed countries (default)"
          }
        },
        {
          "value": "hide_in",
          "label": {
            "ar": "إخفاء في الدول المحددة",
            "en": "Hide in listed countries"
          }
        }
      ],
      "default": "show_in"
    }
  ]
}
