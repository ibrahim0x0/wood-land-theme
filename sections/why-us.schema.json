{
  "template": "sections/why-us.jinja",
  "name": {
    "ar": "لماذا تختارنا",
    "en": "Why Choose Us"
  },
  "settings": [
    {
      "id": "eyebrow",
      "type": "text",
      "label": {
        "ar": "النص الافتتاحي (اختياري)",
        "en": "Eyebrow (optional)"
      },
      "info": {
        "ar": "سطر قصير فوق العنوان. لون النص يُتحكَّم به عبر إعدادات \"عناوين الأقسام\" الشاملة.",
        "en": "Short kicker line above the title. Color is controlled by the global Section Headings settings."
      },
      "default": ""
    },
    {
      "id": "title",
      "type": "text",
      "label": {
        "ar": "العنوان",
        "en": "Title"
      },
      "default": ""
    },
    {
      "id": "subtitle",
      "type": "textarea",
      "label": {
        "ar": "الوصف (اختياري)",
        "en": "Subtitle (optional)"
      },
      "default": ""
    },

    {
      "id": "points",
      "type": "list",
      "label": {
        "ar": "النقاط",
        "en": "Points"
      },
      "info": {
        "ar": "كل نقطة تحتوي على أيقونة ونص. الأمثل 6-9 نقاط. على الجوال تظهر بعمودين، على سطح المكتب بعمود واحد بجانب المعرض.",
        "en": "Each point has an icon and a short text. Sweet spot is 6-9 points. Mobile renders them in 2 columns; desktop stacks them in a single column next to the gallery."
      },
      "max_items": 12,
      "settings": [
        {
          "id": "icon",
          "type": "image",
          "label": {
            "ar": "الأيقونة",
            "en": "Icon"
          },
          "info": {
            "ar": "صورة شفافة مربعة ~80×80 بكسل (PNG/SVG).",
            "en": "Square transparent image ~80×80px (PNG/SVG)."
          }
        },
        {
          "id": "text",
          "type": "textarea",
          "label": {
            "ar": "النص",
            "en": "Text"
          }
        }
      ]
    },
    {
      "id": "gallery_images",
      "type": "list",
      "label": {
        "ar": "صور المعرض السداسي (5 صور)",
        "en": "Hexagonal gallery images (5 images)"
      },
      "info": {
        "ar": "5 صور بشكل سداسي مرتبة كقرص عسل. استخدم PNG شفافة بشكل سداسي ~400×400 بكسل للحصول على أفضل نتيجة. ترك صف فارغ في المنتصف يبقي الفجوة في موضع تلك الصورة بدلاً من إعادة ترتيب الباقي.",
        "en": "5 hexagon-shaped images arranged in a honeycomb pattern. Use transparent PNGs of hexagon-shaped artwork ~400×400px for best results. Leaving a row blank in the middle keeps the gap at that position rather than shifting the rest."
      },
      "max_items": 5,
      "settings": [
        {
          "id": "image",
          "type": "image",
          "label": {
            "ar": "الصورة",
            "en": "Image"
          }
        }
      ]
    },
    {
      "id": "background",
      "type": "select",
      "label": {
        "ar": "── الخلفية",
        "en": "── Background"
      },
      "options": [
        {
          "value": "warm",
          "label": {
            "ar": "كريمي دافئ (مناسب للعسل والمنتجات الطبيعية)",
            "en": "Warm cream (suits honey / natural-product brands)"
          }
        },
        {
          "value": "background",
          "label": {
            "ar": "خلفية الصفحة",
            "en": "Page background"
          }
        },
        {
          "value": "secondary",
          "label": {
            "ar": "ثانوي",
            "en": "Secondary"
          }
        },
        {
          "value": "transparent",
          "label": {
            "ar": "شفاف",
            "en": "Transparent"
          }
        }
      ],
      "default": "warm"
    },
    {
      "id": "enable_animation",
      "type": "checkbox",
      "label": {
        "ar": "── تفعيل تأثير الظهور",
        "en": "── Enable pop-in animation"
      },
      "info": {
        "ar": "تأثير ارتداد لطيف عند ظهور النقاط والصور. يحترم تفضيل تقليل الحركة في النظام.",
        "en": "Subtle elastic pop on first paint. Respects OS-level reduce-motion preference."
      },
      "default": true
    },
    {
      "id": "padding_y",
      "type": "range",
      "label": {
        "ar": "── المسافة العمودية الداخلية",
        "en": "── Vertical padding"
      },
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 50
    },
    {
      "id": "margin_y",
      "type": "range",
      "label": {
        "ar": "── المسافة العمودية الخارجية",
        "en": "── Vertical margin"
      },
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 30
    },
    {
      "id": "border_top",
      "type": "checkbox",
      "label": {
        "ar": "── حد علوي",
        "en": "── Top border"
      },
      "default": false
    },
    {
      "id": "border_bottom",
      "type": "checkbox",
      "label": {
        "ar": "── حد سفلي",
        "en": "── Bottom border"
      },
      "default": false
    },
    {
      "id": "visibility_countries",
      "type": "text",
      "label": {
        "ar": "── إظهار في دول محددة (اختياري)",
        "en": "── Show in specific countries (optional)"
      },
      "info": {
        "ar": "رموز الدول مفصولة بفاصلة (مثل: \"SA, KW, AE\"). اتركه فارغًا لإظهار القسم في كل الدول. الكشف يستخدم رابط المتجر (/ar-sa/, /ar-kw/) ثم session.country كاحتياطي. غير حساس لحالة الأحرف.",
        "en": "Comma-separated country codes (e.g. \"SA, KW, AE\"). Leave empty to show in all countries. Detection uses the storefront URL locale (/ar-sa/, /ar-kw/) first, then session.country as a fallback. Case-insensitive."
      },
      "default": ""
    },
    {
      "id": "visibility_mode",
      "type": "select",
      "label": {
        "ar": "── وضع الاستهداف",
        "en": "── Targeting mode"
      },
      "info": {
        "ar": "إظهار في: يظهر القسم فقط للزوار من الدول المحددة. إخفاء في: يخفى القسم عن الزوار من الدول المحددة. يعمل فقط عند تعبئة قائمة الدول أعلاه.",
        "en": "Show in: section renders only for visitors from the listed countries. Hide in: section hides from visitors in the listed countries. Only takes effect when the country list above has values."
      },
      "options": [
        {
          "value": "show_in",
          "label": {
            "ar": "إظهار في الدول المحددة (افتراضي)",
            "en": "Show in listed countries (default)"
          }
        },
        {
          "value": "hide_in",
          "label": {
            "ar": "إخفاء في الدول المحددة",
            "en": "Hide in listed countries"
          }
        }
      ],
      "default": "show_in"
    }
  ]
}
